# Rails secret key base (required for production)
# Generate with: bundle exec rails secret
SECRET_KEY_BASE=your_secret_key_base_here

# JWT secret key for Devise authentication
# Generate with: bundle exec rails secret
DEVISE_JWT_SECRET_KEY=your_secret_key_here

# Mailer sender address (From header in emails)
MAILER_SENDER=noreply@example.com

# SMTP settings for email delivery
SMTP_ADDRESS=localhost
SMTP_PORT=25
SMTP_DOMAIN=example.com
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENABLE_STARTTLS=false

# POP before SMTP settings (optional)
# Set POP_ADDRESS to enable POP3 authentication before SMTP relay.
# POP_ADDRESS=localhost
# POP_PORT=110
# POP_USERNAME=your_username
# POP_PASSWORD=your_password
# POP_ENABLE_SSL=false

# Application host (used for email links and host authorization)
APP_HOST=example.com

# SSL settings (set to true when behind nginx with SSL)
FORCE_SSL=false

# Puma bind address (optional, for unix socket with nginx)
# PUMA_BIND=unix:///path/to/aion/tmp/sockets/puma.sock

# Database username for production (default: aion)
# DB_USERNAME=aion

# Database password for production
# AION_DATABASE_PASSWORD=your_db_password

# Web Push (VAPID keys)
# 生成: bundle exec rails push:generate_vapid_keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# X list monitoring
X_BEARER_TOKEN=your_x_bearer_token_here
X_LIST_ID=2038215163397251503

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
