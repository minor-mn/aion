# Nginx configuration for Aion (umr.biz)
# Copy to /etc/nginx/sites-available/aion and symlink to sites-enabled.
#
# Usage:
#   sudo cp config/nginx.conf.example /etc/nginx/sites-available/aion
#   sudo ln -s /etc/nginx/sites-available/aion /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

upstream aion_puma {
  # Option 1: Unix socket (recommended, set PUMA_BIND in .env)
  # server unix:/home/nacci/dev/aion/tmp/sockets/puma.sock fail_timeout=0;

  # Option 2: TCP port (default)
  server 127.0.0.1:3000 fail_timeout=0;
}

# HTTP
server {
  listen 80;
  server_name umr.biz;

  # proxy.pac must be accessible via HTTP (browser auto-config)
  location = /proxy.pac {
    root /var/www/html;
    types { application/x-ns-proxy-autoconfig pac; }
  }

  # Everything else redirects to HTTPS
  location / {
    return 301 https://$host$request_uri;
  }
}

# HTTPS
server {
  listen 443 ssl;
  server_name umr.biz;

  ssl_certificate     /etc/letsencrypt/live/umr.biz/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/umr.biz/privkey.pem;
  ssl_protocols       TLSv1.2 TLSv1.3;
  ssl_ciphers         HIGH:!aNULL:!MD5;

  root /home/nacci/dev/aion/public;

  # proxy.pac (also accessible via HTTPS)
  location = /proxy.pac {
    root /var/www/html;
    types { application/x-ns-proxy-autoconfig pac; }
  }

  # Serve static files directly via nginx
  location ^~ /assets/ {
    gzip_static on;
    expires max;
    add_header Cache-Control public;
  }

  location ^~ /css/ {
    gzip_static on;
    expires 1d;
  }

  location ^~ /js/ {
    gzip_static on;
    expires 1d;
  }

  location ^~ /openapi/ {
    gzip_static on;
    expires 1d;
  }

  # Proxy to Puma
  location / {
    try_files $uri @puma;
  }

  location @puma {
    proxy_pass http://aion_puma;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_redirect off;
  }
}
