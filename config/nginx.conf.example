# Nginx configuration for Aion
# Copy to /etc/nginx/sites-available/aion and symlink to sites-enabled.
#
# Usage:
#   1. Replace YOUR_DOMAIN with your actual domain (e.g. example.com)
#   2. Replace /path/to/aion with your app directory (e.g. /home/user/dev/aion)
#   3. sudo cp config/nginx.conf.example /etc/nginx/sites-available/aion
#   4. sudo ln -s /etc/nginx/sites-available/aion /etc/nginx/sites-enabled/
#   5. sudo nginx -t && sudo systemctl reload nginx

upstream aion_puma {
  # Option 1: Unix socket (recommended, set PUMA_BIND in .env)
  # server unix:/path/to/aion/tmp/sockets/puma.sock fail_timeout=0;

  # Option 2: TCP port (default)
  server 127.0.0.1:3000 fail_timeout=0;
}

# HTTP
server {
  listen 80;
  server_name YOUR_DOMAIN;

  # Serve static files via HTTP if needed (e.g. proxy.pac)
  # location = /proxy.pac {
  #   root /var/www/html;
  #   types { application/x-ns-proxy-autoconfig pac; }
  # }

  # Redirect to HTTPS
  location / {
    return 301 https://$host$request_uri;
  }
}

# HTTPS
server {
  listen 443 ssl;
  server_name YOUR_DOMAIN;

  ssl_certificate     /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;
  ssl_protocols       TLSv1.2 TLSv1.3;
  ssl_ciphers         HIGH:!aNULL:!MD5;

  root /path/to/aion/public;

  # Serve static files directly via nginx
  location ^~ /assets/ {
    gzip_static on;
    expires max;
    add_header Cache-Control public;
  }

  location ^~ /css/ {
    gzip_static on;
    expires 1d;
  }

  location ^~ /js/ {
    gzip_static on;
    expires 1d;
  }

  location ^~ /openapi/ {
    gzip_static on;
    expires 1d;
  }

  # Proxy to Puma
  location / {
    try_files $uri @puma;
  }

  location @puma {
    proxy_pass http://aion_puma;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_redirect off;
  }
}
